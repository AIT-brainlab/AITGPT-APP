# this is the template env file. 
# copy this, rename to `local.env`, then put your secrete key
PROJECT_NAME="aitgpt-backend"

# Django Settings
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CHAT_RETRIEVAL_ACCESS_TOKEN=
IS_LOGGING_ENABLED=True

# PostgreSQL Database Settings
DB_HOST=aitgpt_backend_db_v2_dev
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# CORS Settings (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=True

# Superuser Creation (optional - only creates if SUPERUSER_PASSWORD is set)
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=password

# Langflow
LANGFLOW_API_URL=https://<url>/api/v1
LANGFLOW_API_KEY=sk-xxxxxxxxxxxxxxx
LANGFLOW_RUN_ID=
LANGFLOW_REASONING_API_URL=https://<url>/api/v1
LANGFLOW_REASONING_API_KEY=sk-xxxxxxxxxxxxxx
LANGFLOW_REASONING_RUN_ID=

# LogLevel
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
DB_CONN_MAX_AGE=600